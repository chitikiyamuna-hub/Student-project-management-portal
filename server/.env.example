PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Database configuration (Optional)
# If these are left blank or connection fails, the app automatically falls back to an In-Memory DB (persisted to a local JSON file).
# Example MongoDB URI: mongodb://localhost:27017/student_projects or MongoDB Atlas URI
MONGODB_URI=

# Example PostgreSQL URI: postgres://username:password@localhost:5432/database_name
DATABASE_URL=

# Example MySQL URI: mysql://username:password@localhost:3306/database_name
MYSQL_URL=
